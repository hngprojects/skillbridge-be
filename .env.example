NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nestjs_starter
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false
DATABASE_SSL_CA=

# JWT (must be at least 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d
VERIFICATION_OTP_EXPIRES_IN=15m
VERIFICATION_RESEND_LIMIT_PER_HOUR=3

PASSWORD_RESET_EXPIRES_IN=1h
# Optional: one-click reset URL; token is appended in the fragment (#token=…) so it is not sent in Referer. The plaintext reset token is always included in the email body; omitting this only means there is no link.
PASSWORD_RESET_WEB_BASE_URL=

REDIS_URL=redis://localhost:6379

RESEND_API_KEY=some-resend-api-key
RESEND_MAIL_FROM=dummyemail@hng.com

# Google OAuth
GOOGLE_CLIENT_ID=long-random-string.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCS..random-string

#LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/v1/auth/linkedin/callback
LINKEDIN_CLIENT_SECRET=
# Optional (defaults: 15000 ms, 262144 bytes)
# LINKEDIN_HTTP_TIMEOUT_MS=15000
# LINKEDIN_HTTP_MAX_BODY_BYTES=262144

# Misc
CORS_ORIGIN=http://localhost:3000
SWAGGER_ENABLED=true

# Seed admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_FULL_NAME=Admin User
