NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nestjs_starter
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_SSL=false
DATABASE_SSL_CA=

# JWT (must be at least 32 characters each)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-to-a-different-long-random-string
JWT_REFRESH_EXPIRES_IN=7d


RESEND_API_KEY=some-resend-api-key
RESEND_MAIL_FROM=dummyemail@hng.com

# Misc
CORS_ORIGIN=http://localhost:3000
SWAGGER_ENABLED=true

# Seed admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_FULL_NAME=Admin User
